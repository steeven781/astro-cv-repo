---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import AccordionLayout from "../layouts/AccordionLayout.astro";
import Card from "./Card.astro";
import CardCarrousel from "./CardCarrousel.astro";
import ContactCard from "./ContactCard.astro";
import ScrollObserver from "./ScrollObserver.astro";
import CardGrid from "./CardGrid.astro";
import FeaturedProjects from "./FeaturedProjects.astro";

const works = await getCollection("work");
const projects = await getCollection("projects");
const studies = await getCollection("studies");
const certificates = await getCollection("certificates");
const customers = await getCollection("customers");
const contact = await getCollection("contact");
const about = await getCollection("about");
const { Content: AboutContent } = await about[0].render();
const PDF = "/cv-2025.pdf";
---

<div class="join join-vertical gap-1 w-full overflow-x-hidden">
  <ScrollObserver>
    <AccordionLayout title={"About"} titleEs={"Sobre Mí"} icon={"carbon:identification"}>
      <div class="w-full max-w-full space-y-6 py-2">

        <div class="flex flex-col md:flex-row gap-6 md:gap-10">

          <!-- Left column: photo, name, links, stats -->
          <div class="flex flex-col items-center md:items-start gap-4 md:w-5/12 flex-shrink-0">

            <!-- Photo (wrapper border avoids box-shadow clipping) -->
            <div class="relative self-center md:self-start">
              <div class="p-[3px] rounded-2xl bg-primary/25 shadow-xl shadow-primary/10">
                <div class="w-40 h-40 md:w-48 md:h-48 rounded-[14px] overflow-hidden">
                  <img src="/profile.webp" alt="Steeven Medina" class="w-full h-full object-cover transition-transform duration-300 hover:scale-105" />
                </div>
              </div>
              <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center gap-1.5 bg-base-200/90 backdrop-blur-sm border border-primary/30 rounded-full px-2.5 py-1 shadow-md whitespace-nowrap">
                <span class="w-2 h-2 bg-primary rounded-full animate-pulse flex-shrink-0"></span>
                <span class="text-xs font-semibold text-primary">
                  <span class="lang-en">Available</span>
                  <span class="lang-es">Disponible</span>
                </span>
              </div>
            </div>

            <!-- Name + designation + location -->
            <div class="text-center md:text-left mt-3">
              <h2 class="text-2xl md:text-3xl font-bold font-heading">{about[0].data.name}</h2>
              <p class="text-primary font-semibold mt-1">
                <span class="lang-en">{about[0].data.designation}</span>
                <span class="lang-es">{about[0].data.designation_es ?? about[0].data.designation}</span>
              </p>
              <p class="text-secondary/60 text-sm mt-1.5 flex items-center gap-1 justify-center md:justify-start">
                <Icon name="carbon:location" class="w-3.5 h-3.5 flex-shrink-0" />
                {about[0].data.location}
              </p>
            </div>

            <!-- Social links (44px touch targets) -->
            <div class="flex flex-wrap gap-2 justify-center md:justify-start">
              {contact.filter(c => c.data.title !== 'WhatsApp').map(c => (
                <a href={c.data.url} target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-1.5 min-h-[44px] px-3 py-2 rounded-lg border border-base-300/40 hover:border-primary/50 hover:bg-primary/10 hover:text-primary transition-all duration-200 text-secondary/80 text-sm font-medium cursor-pointer">
                  <Icon name={c.data.icon} class="w-4 h-4 flex-shrink-0" />
                  <span>{c.data.title}</span>
                </a>
              ))}
            </div>

            <!-- Bento stats -->
            <div class="grid grid-cols-3 gap-2 w-full">
              <div class="bg-base-200/50 border border-base-300/30 hover:border-primary/30 rounded-xl p-3 text-center transition-colors duration-200">
                <div class="text-2xl font-bold font-heading text-primary">5+</div>
                <div class="text-xs text-secondary/60 mt-0.5 leading-tight">
                  <span class="lang-en">Years<br/>Exp.</span>
                  <span class="lang-es">Años<br/>Exp.</span>
                </div>
              </div>
              <div class="bg-base-200/50 border border-base-300/30 hover:border-primary/30 rounded-xl p-3 text-center transition-colors duration-200">
                <div class="text-2xl font-bold font-heading text-primary">5</div>
                <div class="text-xs text-secondary/60 mt-0.5 leading-tight">
                  <span class="lang-en">Side<br/>Projects</span>
                  <span class="lang-es">Pro-<br/>yectos</span>
                </div>
              </div>
              <div class="bg-base-200/50 border border-base-300/30 hover:border-primary/30 rounded-xl p-3 text-center transition-colors duration-200">
                <div class="text-2xl font-bold font-heading text-primary">10</div>
                <div class="text-xs text-secondary/60 mt-0.5 leading-tight">
                  <span class="lang-en">Certifi-<br/>cations</span>
                  <span class="lang-es">Certifi-<br/>caciones</span>
                </div>
              </div>
            </div>

          </div>

          <!-- Right column: bio -->
          <div class="md:w-7/12 min-w-0">
            <div class="lang-en prose prose-base text-secondary/90 max-w-none break-words leading-relaxed">
              <AboutContent />
            </div>
            {about[0].data.bio_es && (
              <p class="lang-es text-base text-secondary/90 leading-relaxed break-words">
                {about[0].data.bio_es}
              </p>
            )}
          </div>

        </div>
      </div>
    </AccordionLayout>
  </ScrollObserver>

  <ScrollObserver>
    <AccordionLayout title={"Systems I've Built"} titleEs={"Sistemas que He Construido"} icon={"carbon:star"}>
      <FeaturedProjects />
    </AccordionLayout>
  </ScrollObserver>

  <ScrollObserver>
    <AccordionLayout title={"Work"} titleEs={"Experiencia"} icon={"carbon:construction"}>
      <CardGrid collection={works} cardType="timeline" />
    </AccordionLayout>
  </ScrollObserver>

  <ScrollObserver>
    <AccordionLayout title={"Studies"} titleEs={"Estudios"} icon={"carbon:education"}>
      <CardGrid collection={studies} />
    </AccordionLayout>
  </ScrollObserver>

  <ScrollObserver>
    <AccordionLayout title={"Projects"} titleEs={"Proyectos"} icon={"carbon:tools"}>
      <CardGrid collection={projects} />
    </AccordionLayout>
  </ScrollObserver>

  <ScrollObserver>
    <AccordionLayout
      title={"Certifications & Courses"}
      titleEs={"Certificaciones y Cursos"}
      icon={"carbon:certificate"}
    >
      <CardGrid collection={certificates} />
    </AccordionLayout>
  </ScrollObserver>

  <ScrollObserver>
    <AccordionLayout title={"Satisfied Customers"} titleEs={"Clientes Satisfechos"} icon={"carbon:user-admin"}>
      {
        customers.map((item) => {
          return (
            <CardCarrousel
              title={item.data.title}
              titleEs={item.data.title_es}
              logos={item.data.logos}
            />
          );
        })
      }
    </AccordionLayout>
  </ScrollObserver>

  <ScrollObserver>
    <AccordionLayout title={"Files"} titleEs={"Archivos"} icon={"carbon:volume-file-storage"}>
      <div class="flex justify-center w-full">
        <div class="card card-compact w-full max-w-md border border-base-300/30 border-l-4 border-l-primary hover:shadow-lg hover:shadow-primary/5 transition-all duration-200">
          <figure>
            <object data={PDF} type="application/pdf" width="100%"></object>
          </figure>
          <div class="card-body">
            <h2 class="card-title">
              <span class="lang-en">Resume</span>
              <span class="lang-es">Currículum</span>
            </h2>
            <p class="text-secondary/80 text-sm">
              <span class="lang-en">View and download my resume by clicking on the button below</span>
              <span class="lang-es">Visualiza y descarga mi CV haciendo clic en el botón de abajo</span>
            </p>
            <div class="card-actions justify-end mt-2">
              <a target="_blank" href={PDF} class="cursor-pointer">
                <button class="btn btn-primary btn-sm cursor-pointer gap-2">
                  <span class="lang-en">Download resume</span>
                  <span class="lang-es">Descargar CV</span>
                  <Icon name="carbon:document-pdf" class="w-4 h-4" />
                </button>
              </a>
            </div>
          </div>
        </div>
      </div>
    </AccordionLayout>
  </ScrollObserver>

  <ScrollObserver>
    <AccordionLayout title={"Contact"} titleEs={"Contacto"} icon={"carbon:location-person"}>
      <div class="flex flex-wrap content-around gap-4 justify-center">
        {
          contact.filter(c => c.data.title !== 'WhatsApp').map((item) => {
            return (
              <ContactCard
                url={item.data.url}
                url_name={item.data.title}
                icon={item.data.icon}
              />
            );
          })
        }
      </div>
    </AccordionLayout>
  </ScrollObserver>
</div>
