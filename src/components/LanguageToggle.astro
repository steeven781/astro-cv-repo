---
<button
  id="lang-toggle"
  class="flex items-center gap-1.5 min-h-[44px] px-3 py-1.5 font-mono font-bold text-sm tracking-wider border border-base-300/40 rounded-full hover:border-primary/50 hover:text-primary transition-all duration-200 cursor-pointer"
  aria-label="Switch language / Cambiar idioma"
  title="Switch language / Cambiar idioma"
>
  <span class="lang-en">ES</span>
  <span class="lang-es">EN</span>
</button>

<script>
  (function () {
    const btn = document.getElementById("lang-toggle");
    const html = document.documentElement;

    function getLang() {
      return localStorage.getItem("lang") || "en";
    }

    function applyLang(lang: string) {
      html.setAttribute("data-lang", lang);
      html.setAttribute("lang", lang === "es" ? "es-419" : "en-US");
      localStorage.setItem("lang", lang);
    }

    applyLang(getLang());

    btn?.addEventListener("click", () => {
      applyLang(getLang() === "en" ? "es" : "en");
    });
  })();
</script>
