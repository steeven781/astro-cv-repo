---
import "@fontsource-variable/dm-sans";
import "@fontsource-variable/space-grotesk";
import Container from "../components/Container.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import LanguageToggle from "../components/LanguageToggle.astro";
import { Icon } from "astro-icon/components";
---

<html lang="en">
  <head>
    <script is:inline>
      // Apply theme before paint to avoid flash
      if (localStorage.getItem("theme") === null) {
        document.documentElement.setAttribute("data-theme", "black");
      } else {
        document.documentElement.setAttribute("data-theme", localStorage.getItem("theme"));
      }
      // Apply language before paint to avoid flash
      const lang = localStorage.getItem("lang") || "en";
      document.documentElement.setAttribute("data-lang", lang);
      document.documentElement.setAttribute("lang", lang === "es" ? "es-419" : "en-US");
    </script>
    <script>
      import { themeChange } from "theme-change";
      themeChange();
    </script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.webp" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>Steeven Medina CV</title>
  </head>
  <body class="flex flex-col min-h-screen w-full overflow-x-hidden">
    <Header />

    <!-- Top-right controls: lang toggle + theme toggle -->
    <div class="flex items-center gap-2 absolute z-10" style="top: max(1rem, env(safe-area-inset-top)); right: max(1rem, env(safe-area-inset-right));">
      <LanguageToggle />
      <div class="flex items-center gap-1.5 bg-base-200/60 backdrop-blur-sm border border-base-300/30 rounded-full px-3 py-1.5 shadow-sm min-h-[44px]">
        <Icon name="carbon:moon" class="w-3.5 h-3.5 opacity-70" />
        <input
          type="checkbox"
          data-toggle-theme="black,lofi"
          data-act-class="ACTIVECLASS"
          class="toggle toggle-xs mx-0.5 bg-secondary"
          checked
        />
        <Icon name="carbon:light" class="w-3.5 h-3.5 opacity-70" />
      </div>
    </div>

    <div class="w-full px-4 sm:px-6 lg:px-8 mt-2">
      <div class="divider mx-auto h-px max-w-3xl bg-primary/20"></div>
    </div>
    <main class="flex-grow w-full px-4 sm:px-6 lg:px-8 py-4 overflow-x-hidden">
      <div class="max-w-4xl mx-auto w-full overflow-x-hidden">
        <Container />
      </div>
    </main>
    <Footer class="flex justify-center items-center py-4" />
  </body>
</html>

<style is:global>
  html, body {
    font-family: "DM Sans Variable", "DM Sans", sans-serif;
    font-size: 16px;
    max-width: 100vw;
    overflow-x: hidden;
  }

  body {
    padding-left: env(safe-area-inset-left);
    padding-right: env(safe-area-inset-right);
    padding-bottom: env(safe-area-inset-bottom);
  }

  h1, h2, h3, h4, h5, h6,
  .font-heading {
    font-family: "Space Grotesk Variable", "Space Grotesk", "DM Sans Variable", sans-serif;
  }

  * {
    word-wrap: break-word;
    overflow-wrap: break-word;
    box-sizing: border-box;
  }

  .prose {
    max-width: 100% !important;
    font-size: 1rem;
    line-height: 1.7;
  }

  .prose p, .prose li, .prose td, .prose th {
    word-break: break-word;
    overflow-wrap: break-word;
    font-size: 1rem;
  }

  .badge {
    user-select: none;
  }

  .overflow-y-scroll::-webkit-scrollbar {
    width: 3px;
  }

  .overflow-y-scroll::-webkit-scrollbar-thumb {
    background-color: oklch(var(--s));
  }

  .overflow-y-scroll {
    scrollbar-width: 1px;
  }

  /* ── Language switching ──────────────────────────── */
  .lang-es { display: none; }

  html[data-lang="es"] .lang-es { display: revert; }
  html[data-lang="es"] .lang-en { display: none; }
  /* ─────────────────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
